# ── Required ───────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# AI API keys (comma-separated — if one fails the next is tried automatically)
# For Google Gemini free tier: https://aistudio.google.com/app/apikey
# For FreeLLMAPI (self-hosted): use your freellmapi-... bearer token
AI_API_KEYS=key1,key2,key3

# ── AI Configuration ───────────────────────────────────────────────────────────

# Base URL for the OpenAI-compatible endpoint
# Google Gemini direct:
#   https://generativelanguage.googleapis.com/v1beta/openai/
# Your self-hosted FreeLLMAPI instance:
#   https://your-freellmapi.onrender.com/v1
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Model to use (must be supported by your chosen AI_BASE_URL)
# Google Gemini:  gemini-2.5-flash  |  gemini-2.0-flash  |  gemini-1.5-pro
# FreeLLMAPI:     any model in your fallback chain (e.g. gpt-4o-mini, llama-3-70b)
AI_MODEL=gemini-2.5-flash

# ── Optional ───────────────────────────────────────────────────────────────────

# Telegram channel username for forced subscription (leave empty to disable)
# Example: @mychannel  or  -1001234567890
FORCE_SUB_CHANNEL=

# Bot display name shown in welcome messages
BOT_NAME=بوت البحث الأكاديمي العراقي

# Flask server port (Render sets this automatically — do not change on Render)
PORT=8080
